# Copy this file to .env and add your API key for your chosen provider.
# Only one key is needed depending on which PROVIDER you set in ai/suggest.py

# Google Gemini (default) — get key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional) — get key at https://platform.openai.com
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (optional) — get key at https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
